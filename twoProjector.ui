                   <!-- ── 坐标变换 ── -->
                   <item>
                    <widget class="QGroupBox" name="pcTransformGroupBox">
                     <property name="title"><string>坐标变换</string></property>
                     <layout class="QVBoxLayout" name="pcTransformLayout">
                      <item>
                       <layout class="QHBoxLayout" name="pcAlignRow">
                        <item>
                         <widget class="QPushButton" name="pcBtnPCAAlign">
                          <property name="text"><string>PCA对齐</string></property>
                          <property name="toolTip"><string>主成分轴自动对齐至XYZ坐标</string></property>
                         </widget>
                        </item>
                        <item>
                         <widget class="QPushButton" name="pcBtnCenter">
                          <property name="text"><string>居中原点</string></property>
                          <property name="toolTip"><string>平移重心到原点</string></property>
                         </widget>
                        </item>
                        <item>
                         <widget class="QPushButton" name="pcBtnLevelPlane">
                          <property name="text"><string>基准平面校正</string></property>
                          <property name="toolTip"><string>将拟合平面旋转至水平</string></property>
                         </widget>
                        </item>
                       </layout>
                      </item>
                      <item>
                       <layout class="QHBoxLayout" name="pcRotateRow">
                        <item><widget class="QLabel" name="pcLblRotate"><property name="text"><string>旋转(°):</string></property></widget></item>
                        <item><widget class="QLabel" name="pcLblRX"><property name="text"><string>Rx</string></property></widget></item>
                        <item>
                         <widget class="QDoubleSpinBox" name="pcSpinRotX">
                          <property name="minimum"><double>-360.000000000000000</double></property>
                          <property name="maximum"><double>360.000000000000000</double></property>
                          <property name="singleStep"><double>1.000000000000000</double></property>
                         </widget>
                        </item>
                        <item><widget class="QLabel" name="pcLblRY"><property name="text"><string>Ry</string></property></widget></item>
                        <item>
                         <widget class="QDoubleSpinBox" name="pcSpinRotY">
                          <property name="minimum"><double>-360.000000000000000</double></property>
                          <property name="maximum"><double>360.000000000000000</double></property>
                          <property name="singleStep"><double>1.000000000000000</double></property>
                         </widget>
                        </item>
                        <item><widget class="QLabel" name="pcLblRZ"><property name="text"><string>Rz</string></property></widget></item>
                        <item>
                         <widget class="QDoubleSpinBox" name="pcSpinRotZ">
                          <property name="minimum"><double>-360.000000000000000</double></property>
                          <property name="maximum"><double>360.000000000000000</double></property>
                          <property name="singleStep"><double>1.000000000000000</double></property>
                         </widget>
                        </item>
                       </layout>
                      </item>
                      <item>
                       <layout class="QHBoxLayout" name="pcTranslateRow">
                        <item><widget class="QLabel" name="pcLblTranslate"><property name="text"><string>平移(mm):</string></property></widget></item>
                        <item><widget class="QLabel" name="pcLblTX"><property name="text"><string>Tx</string></property></widget></item>
                        <item>
                         <widget class="QDoubleSpinBox" name="pcSpinTransX">
                          <property name="minimum"><double>-1000.000000000000000</double></property>
                          <property name="maximum"><double>1000.000000000000000</double></property>
                          <property name="singleStep"><double>0.100000000000000</double></property>
                         </widget>
                        </item>
                        <item><widget class="QLabel" name="pcLblTY"><property name="text"><string>Ty</string></property></widget></item>
                        <item>
                         <widget class="QDoubleSpinBox" name="pcSpinTransY">
                          <property name="minimum"><double>-1000.000000000000000</double></property>
                          <property name="maximum"><double>1000.000000000000000</double></property>
                          <property name="singleStep"><double>0.100000000000000</double></property>
                         </widget>
                        </item>
                        <item><widget class="QLabel" name="pcLblTZ"><property name="text"><string>Tz</string></property></widget></item>
                        <item>
                         <widget class="QDoubleSpinBox" name="pcSpinTransZ">
                          <property name="minimum"><double>-1000.000000000000000</double></property>
                          <property name="maximum"><double>1000.000000000000000</double></property>
                          <property name="singleStep"><double>0.100000000000000</double></property>
                         </widget>
                        </item>
                       </layout>
                      </item>
                      <item>
                       <widget class="QPushButton" name="pcBtnApplyTransform">
                        <property name="text"><string>应用变换</string></property>
                        <property name="toolTip"><string>将旋转和平移应用到点云</string></property>
                       </widget>
                      </item>
                     </layout>
                    </widget>
                   </item>
  
                   <!-- ── 视图切换 ── -->
                   <item>
                    <widget class="QGroupBox" name="pcViewGroupBox">
                     <property name="title"><string>视图切换</string></property>
                     <layout class="QGridLayout" name="pcViewGrid">
                      <item row="0" column="0">
                       <widget class="QPushButton" name="pcBtnViewFront">
                        <property name="text"><string>正视图 (XZ)</string></property>
                        <property name="toolTip"><string>前视图：沿Y轴负方向</string></property>
                       </widget>
                      </item>
                      <item row="0" column="1">
                       <widget class="QPushButton" name="pcBtnViewBack">
                        <property name="text"><string>后视图</string></property>
                        <property name="toolTip"><string>后视图：沿Y轴正方向</string></property>
                       </widget>
                      </item>
                      <item row="1" column="0">
                       <widget class="QPushButton" name="pcBtnViewLeft">
                        <property name="text"><string>左视图 (YZ)</string></property>
                        <property name="toolTip"><string>左视图：沿X轴正方向</string></property>
                       </widget>
                      </item>
                      <item row="1" column="1">
                       <widget class="QPushButton" name="pcBtnViewRight">
                        <property name="text"><string>右视图</string></property>
                        <property name="toolTip"><string>右视图：沿X轴负方向</string></property>
                       </widget>
                      </item>
                      <item row="2" column="0">
                       <widget class="QPushButton" name="pcBtnViewTop">
                        <property name="text"><string>俯视图 (XY)</string></property>
                        <property name="toolTip"><string>顶视图：沿Z轴负方向</string></property>
                       </widget>
                      </item>
                      <item row="2" column="1">
                       <widget class="QPushButton" name="pcBtnViewBottom">
                        <property name="text"><string>仰视图</string></property>
                        <property name="toolTip"><string>底视图：沿Z轴正方向</string></property>
                       </widget>
                      </item>
                      <item row="3" column="0">
                       <widget class="QPushButton" name="pcBtnViewIsometric">
                        <property name="text"><string>等轴测</string></property>
                        <property name="toolTip"><string>等轴测视图</string></property>
                       </widget>
                      </item>
                      <item row="3" column="1">
                       <widget class="QPushButton" name="pcBtnViewReset">
                        <property name="text"><string>重置视图</string></property>
                        <property name="toolTip"><string>恢复默认摄像机位置</string></property>
                       </widget>
                      </item>
                     </layout>
                    </widget>
                   </item>
  
                   <!-- ── 导出 ── -->
                   <item>
                    <widget class="QGroupBox" name="pcExportGroupBox">
                     <property name="title"><string>导出</string></property>
                     <layout class="QGridLayout" name="pcExportGrid">
                      <item row="0" column="0">
                       <widget class="QPushButton" name="pcBtnExportPLY">
                        <property name="text"><string>导出 PLY</string></property>
                       </widget>
                      </item>
                      <item row="0" column="1">
                       <widget class="QPushButton" name="pcBtnExportPCD">
                        <property name="text"><string>导出 PCD</string></property>
                       </widget>
                      </item>
                      <item row="1" column="0">
                       <widget class="QPushButton" name="pcBtnExportCSV">
                        <property name="text"><string>导出 CSV</string></property>
                       </widget>
                      </item>
                      <item row="1" column="1">
                       <widget class="QPushButton" name="pcBtnScreenshot">
                        <property name="text"><string>视图截图</string></property>
                        <property name="toolTip"><string>将当前3D视图保存为图片</string></property>
                       </widget>
                      </item>
                     </layout>
                    </widget>
                   </item>
  
                   <!-- 弹簧占位 -->
                   <item>
                    <spacer name="pcScrollBottomSpacer">
                     <property name="orientation"><enum>Qt::Vertical</enum></property>
                     <property name="sizeHint" stdset="0"><size><width>20</width><height>10</height></size></property>
                    </spacer>
                   </item>
  
                  </layout>
                 </widget>
                </widget>
               </item>
              </layout>
              </widget>
             <!-- Right: 3D视图 -->
              <widget class="QWidget" name="resCloud3DWidget">
              <layout class="QVBoxLayout" name="resCloudLayout" stretch="0,20,1">
             <item>
              <widget class="QGroupBox" name="resCloudCtrlGroupBox">
               <property name="title"><string>点云显示控制</string></property>
               <layout class="QHBoxLayout" name="resCloudCtrlLayout">
                <item><widget class="QCheckBox" name="resCheckGrid"><property name="text"><string>网格显示</string></property></widget></item>
                <item><widget class="QCheckBox" name="resCheckWireframe"><property name="text"><string>线框模式</string></property></widget></item>
                <item><widget class="QCheckBox" name="resCheckInvert"><property name="text"><string>高度反转</string></property></widget></item>
                <item><widget class="QCheckBox" name="pcCheckHeightColor"><property name="text"><string>高度染色</string></property></widget></item>
                <item>
                 <spacer name="resCloudSpacer">
                  <property name="orientation"><enum>Qt::Horizontal</enum></property>
                  <property name="sizeHint" stdset="0"><size><width>400</width><height>20</height></size></property>
                 </spacer>
                </item>
               </layout>
              </widget>
             </item>
             <item>
              <widget class="QLabel" name="resCloudLabel">
               <property name="styleSheet"><string notr="true">background-color: #2b2b2b; color: white;</string></property>
               <property name="text"><string>[3D 点云渲染区]</string></property>
               <property name="alignment"><set>Qt::AlignCenter</set></property>
               <property name="scaledContents"><bool>true</bool></property>
              </widget>
             </item>
             <!-- 重建日志 (嵌入3D点云下方) -->
             <item>
              <widget class="QGroupBox" name="resLogGroupBox">
               <property name="title"><string>重建日志</string></property>
               <property name="maximumSize"><size><width>16777215</width><height>150</height></size></property>
               <layout class="QVBoxLayout" name="resLogInnerLayout">
                <item>
                 <widget class="QTextEdit" name="resLogText">
                  <property name="readOnly"><bool>false</bool></property>
                  <property name="maximumSize"><size><width>16777215</width><height>120</height></size></property>
                 </widget>
                </item>
               </layout>
              </widget>
             </item>
              </layout>
              </widget>
              </widget>
             </item>
            </layout>
           </widget>
         </widget>
         </widget>
        </item>
       </layout>
      </widget>

      <!-- ==================== Tab 3: BGA共面度测量 ==================== -->
      <widget class="QWidget" name="bgaWidget">
       <attribute name="title">
        <string>BGA共面度测量</string>
       </attribute>
       <layout class="QHBoxLayout" name="bgaMainLayout" stretch="2,5">
        <item>
         <layout class="QVBoxLayout" name="bgaLeftLayout">
          <!-- 共面度测量控制 -->
          <item>
           <widget class="QGroupBox" name="bgaCtrlGroupBox">
            <property name="title"><string>共面度测量控制</string></property>
            <layout class="QVBoxLayout" name="bgaCtrlLayout">
             <item>
              <layout class="QHBoxLayout" name="bgaCountRow">
               <item><widget class="QLabel" name="bgaLblCount"><property name="text"><string>测量次数:</string></property></widget></item>
               <item>
                <widget class="QSpinBox" name="bgaSpinCount">
                 <property name="minimum"><number>1</number></property>
                 <property name="maximum"><number>100</number></property>
                 <property name="value"><number>10</number></property>
                </widget>
               </item>
              </layout>
             </item>
             <item>
              <layout class="QHBoxLayout" name="bgaImgFolderRow">
               <item><widget class="QLabel" name="bgaLblImgFolder"><property name="text"><string>扫描根目录:</string></property></widget></item>
               <item><widget class="QLineEdit" name="bgaEditImgFolder"><property name="placeholderText"><string>含 1/(pro1) 和 2/(pro2) 子目录，如 data/pic/BGA静态</string></property></widget></item>
               <item><widget class="QPushButton" name="bgaBtnImgFolderBrowse"><property name="maximumSize"><size><width>50</width><height>16777215</height></size></property><property name="text"><string>浏览</string></property></widget></item>
              </layout>
             </item>
             <item>
              <layout class="QHBoxLayout" name="bgaCloudFolderRow">
               <item><widget class="QLabel" name="bgaLblCloudFolder"><property name="text"><string>保存路径:</string></property></widget></item>
               <item><widget class="QLineEdit" name="bgaEditCloudFolder"><property name="placeholderText"><string>测量结果保存路径（可选）</string></property></widget></item>
               <item><widget class="QPushButton" name="bgaBtnCloudFolderBrowse"><property name="maximumSize"><size><width>50</width><height>16777215</height></size></property><property name="text"><string>浏览</string></property></widget></item>
              </layout>
             </item>
             <item><widget class="QPushButton" name="bgaBtnStart"><property name="styleSheet"><string notr="true">background-color: rgb(255,255,255);</string></property><property name="text"><string>开始测量</string></property></widget></item>
             <item><widget class="QPushButton" name="bgaBtnPlot"><property name="styleSheet"><string notr="true">background-color: rgb(255,255,255);</string></property><property name="text"><string>数据画图</string></property></widget></item>
             <item><widget class="QPushButton" name="bgaBtnBallShow"><property name="styleSheet"><string notr="true">background-color: rgb(255,255,255);</string></property><property name="text"><string>焊球定位显示</string></property></widget></item>
             <item><widget class="QPushButton" name="bgaBtnImport"><property name="styleSheet"><string notr="true">background-color: rgb(255,255,255);</string></property><property name="text"><string>数据导入</string></property></widget></item>
             <item><widget class="QPushButton" name="bgaBtnSave"><property name="styleSheet"><string notr="true">background-color: rgb(255,255,255);</string></property><property name="text"><string>结果保存</string></property></widget></item>
            </layout>
           </widget>
          </item>
          <!-- 共面度数据 -->
          <item>
           <widget class="QGroupBox" name="bgaDataGroupBox">
            <property name="title"><string>共面度数据</string></property>
            <layout class="QVBoxLayout" name="bgaDataLayout">
             <item>
              <widget class="QTextEdit" name="bgaDataText">
               <property name="readOnly"><bool>false</bool></property>
               <property name="placeholderText"><string>共面度测量结果将在此显示...</string></property>
              </widget>
             </item>
            </layout>
           </widget>
          </item>
          <!-- BGA日志 -->
          <item>
           <widget class="QGroupBox" name="bgaLogGroupBox">
            <property name="title"><string>测量日志</string></property>
            <property name="sizePolicy">
             <sizepolicy hsizetype="Preferred" vsizetype="Maximum">
              <horstretch>0</horstretch><verstretch>0</verstretch>
             </sizepolicy>
            </property>
            <layout class="QVBoxLayout" name="bgaLogLayout">
             <property name="topMargin"><number>2</number></property>
             <property name="bottomMargin"><number>2</number></property>
             <item>
              <widget class="QTextEdit" name="bgaLogText">
               <property name="readOnly"><bool>true</bool></property>
               <property name="placeholderText"><string>BGA测量日志...</string></property>
               <property name="minimumSize"><size><width>0</width><height>80</height></size></property>
               <property name="maximumSize"><size><width>16777215</width><height>100</height></size></property>
              </widget>
             </item>
            </layout>
           </widget>
          </item>
         </layout>
        </item>
        <item>
         <layout class="QVBoxLayout" name="bgaRightLayout" stretch="1,1">
          <!-- 测量结果显示 (直方图+折线图) -->
          <item>
           <widget class="QGroupBox" name="bgaChartGroupBox">
            <property name="title"><string>测量结果显示</string></property>
            <layout class="QHBoxLayout" name="bgaChartLayout">
             <item>
              <widget class="QLabel" name="bgaBarLabel">
               <property name="text"><string>直方图</string></property>
               <property name="alignment"><set>Qt::AlignCenter</set></property>
               <property name="scaledContents"><bool>true</bool></property>
              </widget>
             </item>
             <item>
              <widget class="QLabel" name="bgaLineLabel">
               <property name="text"><string>折线图</string></property>
               <property name="alignment"><set>Qt::AlignCenter</set></property>
               <property name="scaledContents"><bool>true</bool></property>
              </widget>
             </item>
            </layout>
           </widget>
          </item>
          <!-- 焊球定位结果 -->
          <item>
           <widget class="QGroupBox" name="bgaBallGroupBox">
            <property name="title"><string>焊球定位结果</string></property>
            <layout class="QVBoxLayout" name="bgaBallLayout">
             <item>
              <widget class="QLabel" name="bgaBallLabel">
               <property name="text"><string>焊球定位结果图</string></property>
               <property name="alignment"><set>Qt::AlignCenter</set></property>
               <property name="scaledContents"><bool>true</bool></property>
              </widget>
             </item>
            </layout>
           </widget>
          </item>
         </layout>
        </item>
       </layout>
      </widget>

      <!-- ==================== Tab 4: QFP共面度测量 ==================== -->
      <widget class="QWidget" name="qfpWidget">
       <attribute name="title">
        <string>QFP共面度测量</string>
       </attribute>
       <layout class="QHBoxLayout" name="qfpMainLayout" stretch="2,5">
        <item>
         <layout class="QVBoxLayout" name="qfpLeftLayout">
          <!-- 共面度测量控制 -->
          <item>
           <widget class="QGroupBox" name="qfpCtrlGroupBox">
            <property name="title"><string>共面度测量控制</string></property>
            <layout class="QVBoxLayout" name="qfpCtrlLayout">
             <item>
              <layout class="QHBoxLayout" name="qfpCountRow">
               <item><widget class="QLabel" name="qfpLblCount"><property name="text"><string>测量次数:</string></property></widget></item>
               <item>
                <widget class="QSpinBox" name="qfpSpinCount">
                 <property name="minimum"><number>1</number></property>
                 <property name="maximum"><number>100</number></property>
                 <property name="value"><number>10</number></property>
                </widget>
               </item>
              </layout>
             </item>
             <item>
              <layout class="QHBoxLayout" name="qfpImgFolderRow">
               <item><widget class="QLabel" name="qfpLblImgFolder"><property name="text"><string>图像文件夹:</string></property></widget></item>
               <item><widget class="QLineEdit" name="qfpEditImgFolder"><property name="placeholderText"><string>包含 1.bmp, 2.bmp ... 的文件夹</string></property></widget></item>
               <item><widget class="QPushButton" name="qfpBtnImgFolderBrowse"><property name="maximumSize"><size><width>50</width><height>16777215</height></size></property><property name="text"><string>浏览</string></property></widget></item>
              </layout>
             </item>
             <item>
              <layout class="QHBoxLayout" name="qfpCloudFolderRow">
               <item><widget class="QLabel" name="qfpLblCloudFolder"><property name="text"><string>点云文件夹:</string></property></widget></item>
               <item><widget class="QLineEdit" name="qfpEditCloudFolder"><property name="placeholderText"><string>包含 1.ply, 2.ply ... 的文件夹</string></property></widget></item>
               <item><widget class="QPushButton" name="qfpBtnCloudFolderBrowse"><property name="maximumSize"><size><width>50</width><height>16777215</height></size></property><property name="text"><string>浏览</string></property></widget></item>
              </layout>
             </item>
             <item><widget class="QPushButton" name="qfpBtnStart"><property name="styleSheet"><string notr="true">background-color: rgb(255,255,255);</string></property><property name="text"><string>开始测量</string></property></widget></item>
             <item><widget class="QPushButton" name="qfpBtnPlot"><property name="styleSheet"><string notr="true">background-color: rgb(255,255,255);</string></property><property name="text"><string>数据画图</string></property></widget></item>
             <item><widget class="QPushButton" name="qfpBtnPinShow"><property name="styleSheet"><string notr="true">background-color: rgb(255,255,255);</string></property><property name="text"><string>引脚分割显示</string></property></widget></item>
             <item><widget class="QPushButton" name="qfpBtnImport"><property name="styleSheet"><string notr="true">background-color: rgb(255,255,255);</string></property><property name="text"><string>数据导入</string></property></widget></item>
             <item><widget class="QPushButton" name="qfpBtnSave"><property name="styleSheet"><string notr="true">background-color: rgb(255,255,255);</string></property><property name="text"><string>结果保存</string></property></widget></item>
            </layout>
           </widget>
          </item>
          <!-- 共面度与翘曲度数据 -->
          <item>
           <widget class="QGroupBox" name="qfpDataGroupBox">
            <property name="title"><string>共面度与翘曲度数据</string></property>
            <layout class="QVBoxLayout" name="qfpDataLayout">
             <item>
              <widget class="QTextEdit" name="qfpDataText">
               <property name="readOnly"><bool>false</bool></property>
               <property name="placeholderText"><string>QFP共面度/翘曲度结果将在此显示...</string></property>
              </widget>
             </item>
            </layout>
           </widget>
          </item>
          <!-- QFP日志 -->
          <item>
           <widget class="QGroupBox" name="qfpLogGroupBox">
            <property name="title"><string>测量日志</string></property>
            <property name="sizePolicy">
             <sizepolicy hsizetype="Preferred" vsizetype="Maximum">
              <horstretch>0</horstretch><verstretch>0</verstretch>
             </sizepolicy>
            </property>
            <layout class="QVBoxLayout" name="qfpLogLayout">
             <property name="topMargin"><number>2</number></property>
             <property name="bottomMargin"><number>2</number></property>
             <item>
              <widget class="QTextEdit" name="qfpLogText">
               <property name="readOnly"><bool>true</bool></property>
               <property name="placeholderText"><string>QFP测量日志...</string></property>
               <property name="minimumSize"><size><width>0</width><height>80</height></size></property>
