      <!-- ==================== Tab 2: 系统重建 ==================== -->
      <widget class="QWidget" name="resWidget">
       <attribute name="title">
        <string>系统重建</string>
       </attribute>
       <layout class="QVBoxLayout" name="resMainWrapLayout">
        <!-- 收起/展开参数面板 工具栏 -->
        <item>
         <layout class="QHBoxLayout" name="resToggleToolbar">
          <item>
           <widget class="QPushButton" name="resBtnTogglePanel">
            <property name="text"><string>◀ 收起参数面板</string></property>
            <property name="maximumSize"><size><width>140</width><height>28</height></size></property>
            <property name="styleSheet"><string>font-size:12px; padding:2px 8px;</string></property>
           </widget>
          </item>
          <item>
           <spacer name="resToggleSpacer">
            <property name="orientation"><enum>Qt::Horizontal</enum></property>
            <property name="sizeHint" stdset="0"><size><width>40</width><height>20</height></size></property>
           </spacer>
          </item>
         </layout>
        </item>
        <item>
         <widget class="QSplitter" name="resSplitter">
          <property name="orientation"><enum>Qt::Horizontal</enum></property>
          <widget class="QWidget" name="resLeftWidget">
         <layout class="QVBoxLayout" name="resLeftLayout">
          <!-- 文件设置 -->
          <item>
           <widget class="QGroupBox" name="resFileGroupBox">
            <property name="title"><string>文件设置</string></property>
            <property name="checkable"><bool>true</bool></property>
            <property name="checked"><bool>true</bool></property>
            <layout class="QVBoxLayout" name="resFileLayout">
             <item>
              <layout class="QHBoxLayout" name="resCalPro1Row">
               <item><widget class="QLabel" name="resLblCalPro1"><property name="text"><string>标定数据文件夹:</string></property></widget></item>
               <item><widget class="QLineEdit" name="resEditCalPro1"><property name="text"><string>data/calibrationResult/raw</string></property><property name="placeholderText"><string>选择包含 X.raw, allK_i1.raw 等的文件夹</string></property></widget></item>
               <item><widget class="QPushButton" name="resBtnCalPro1Browse"><property name="maximumSize"><size><width>50</width><height>16777215</height></size></property><property name="text"><string>浏览</string></property></widget></item>
              </layout>
             </item>
             <item>
              <layout class="QHBoxLayout" name="resScanPro1Row">
               <item><widget class="QLabel" name="resLblScanPro1"><property name="text"><string>Pro1扫描文件夹:</string></property></widget></item>
               <item><widget class="QLineEdit" name="resEditScanPro1"><property name="text"><string>data/pic/BGA静态/1/1</string></property><property name="placeholderText"><string>选择Pro1的图像子文件夹, 如 .../1/1</string></property></widget></item>
               <item><widget class="QPushButton" name="resBtnScanPro1Browse"><property name="maximumSize"><size><width>50</width><height>16777215</height></size></property><property name="text"><string>浏览</string></property></widget></item>
              </layout>
             </item>
             <item>
              <layout class="QHBoxLayout" name="resScanPro2Row">
               <item><widget class="QLabel" name="resLblScanPro2"><property name="text"><string>Pro2扫描文件夹:</string></property></widget></item>
               <item><widget class="QLineEdit" name="resEditScanPro2"><property name="text"><string>data/pic/BGA静态/2/1</string></property><property name="placeholderText"><string>Pro2的图像子文件夹（自动填充）</string></property></widget></item>
               <item><widget class="QPushButton" name="resBtnScanPro2Browse"><property name="maximumSize"><size><width>50</width><height>16777215</height></size></property><property name="text"><string>浏览</string></property></widget></item>
              </layout>
             </item>
             <item>
              <layout class="QHBoxLayout" name="resEpiRow">
               <item><widget class="QLabel" name="resLblEpiFile"><property name="text"><string>极线参数文件:</string></property></widget></item>
               <item><widget class="QLineEdit" name="resEditEpiFile"><property name="text"><string>D:/Calibration/epipolar_params.mat</string></property></widget></item>
               <item><widget class="QPushButton" name="resBtnEpiBrowse"><property name="maximumSize"><size><width>50</width><height>16777215</height></size></property><property name="text"><string>浏览</string></property></widget></item>
              </layout>
             </item>
            </layout>
           </widget>
          </item>
          <!-- 双光栅重建参数 -->
          <item>
           <widget class="QGroupBox" name="resDualGroupBox">
            <property name="title"><string>双光栅重建参数</string></property>
            <property name="checkable"><bool>true</bool></property>
            <property name="checked"><bool>true</bool></property>
            <layout class="QVBoxLayout" name="resDualLayout">
             <item>
              <layout class="QHBoxLayout" name="resDecodeRow">
               <item><widget class="QLabel" name="resLblDecode"><property name="text"><string>解码类型:</string></property></widget></item>
               <item><widget class="QComboBox" name="resComboDecodeType"><item><property name="text"><string>multi_freq</string></property></item></widget></item>
              </layout>
             </item>
             <item>
              <layout class="QHBoxLayout" name="resOrderedRow">
               <item><widget class="QLabel" name="resLblOrdered"><property name="text"><string>生成有序点云:</string></property></widget></item>
               <item><widget class="QCheckBox" name="resCheckOrdered"><property name="checked"><bool>true</bool></property><property name="text"><string/></property></widget></item>
              </layout>
             </item>
             <!-- 解码参数设置 -->
             <item>
              <widget class="QGroupBox" name="resFreqGroupBox">
               <property name="title"><string>解码参数设置</string></property>
               <layout class="QGridLayout" name="resFreqGrid">
                <item row="0" column="0"><widget class="QLabel" name="resLblFreq1"><property name="text"><string>频率1:</string></property></widget></item>
                <item row="0" column="1"><widget class="QSpinBox" name="resSpinFreq1"><property name="maximum"><number>200</number></property><property name="value"><number>64</number></property></widget></item>
                <item row="0" column="2"><widget class="QLabel" name="resLblShift1"><property name="text"><string>频率1相移数:</string></property></widget></item>
                <item row="0" column="3"><widget class="QSpinBox" name="resSpinShift1"><property name="value"><number>8</number></property></widget></item>
                <item row="1" column="0"><widget class="QLabel" name="resLblFreq2"><property name="text"><string>频率2:</string></property></widget></item>
                <item row="1" column="1"><widget class="QSpinBox" name="resSpinFreq2"><property name="maximum"><number>200</number></property><property name="value"><number>56</number></property></widget></item>
                <item row="1" column="2"><widget class="QLabel" name="resLblShift2"><property name="text"><string>频率2相移数:</string></property></widget></item>
                <item row="1" column="3"><widget class="QSpinBox" name="resSpinShift2"><property name="value"><number>8</number></property></widget></item>
                <item row="2" column="0"><widget class="QLabel" name="resLblFreq3"><property name="text"><string>频率3:</string></property></widget></item>
                <item row="2" column="1"><widget class="QSpinBox" name="resSpinFreq3"><property name="maximum"><number>200</number></property><property name="value"><number>63</number></property></widget></item>
                <item row="2" column="2"><widget class="QLabel" name="resLblShift3"><property name="text"><string>频率3相移数:</string></property></widget></item>
                <item row="2" column="3"><widget class="QSpinBox" name="resSpinShift3"><property name="value"><number>8</number></property></widget></item>
                <item row="3" column="0"><widget class="QLabel" name="resLblModThresh"><property name="text"><string>调制度阈值:</string></property></widget></item>
                <item row="3" column="1"><widget class="QDoubleSpinBox" name="resDblSpinModThresh"><property name="value"><double>0.700000000000000</double></property></widget></item>
               </layout>
              </widget>
             </item>
             <!-- 重建算法参数 -->
             <item>
              <widget class="QGroupBox" name="resAlgoGroupBox">
               <property name="title"><string>重建算法参数</string></property>
               <layout class="QGridLayout" name="resAlgoGrid" columnstretch="1,2">
                <item row="0" column="0"><widget class="QLabel" name="resLblDepthApply"><property name="text"><string>应用深度范围:</string></property></widget></item>
                <item row="0" column="1"><widget class="QCheckBox" name="resCheckDepthRange"><property name="checked"><bool>true</bool></property><property name="text"><string/></property></widget></item>
                <item row="1" column="0"><widget class="QLabel" name="resLblDepthMin"><property name="text"><string>最小深度(mm):</string></property></widget></item>
                <item row="1" column="1"><widget class="QLineEdit" name="resEditDepthMin"><property name="text"><string>50.0</string></property></widget></item>
                <item row="2" column="0"><widget class="QLabel" name="resLblDepthMax"><property name="text"><string>最大深度(mm):</string></property></widget></item>
                <item row="2" column="1"><widget class="QLineEdit" name="resEditDepthMax"><property name="text"><string>210.0</string></property></widget></item>
                <item row="3" column="0"><widget class="QLabel" name="resLblPhaseThresh"><property name="text"><string>相位差阈值:</string></property></widget></item>
