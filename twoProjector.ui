         </layout>
        </item>
        <item>
         <widget class="QTabWidget" name="qfpResultTabWidget">
          <property name="currentIndex"><number>0</number></property>
          <!-- 引脚分割 -->
          <widget class="QWidget" name="qfpSegTab">
           <attribute name="title"><string>引脚分割</string></attribute>
           <layout class="QVBoxLayout" name="qfpSegTabLayout">
            <item>
             <widget class="QLabel" name="qfpSegLabel">
              <property name="text"><string>引脚分割结果图</string></property>
              <property name="alignment"><set>Qt::AlignCenter</set></property>
             </widget>
            </item>
           </layout>
          </widget>
          <!-- 测量结果 (2×2 网格) -->
          <widget class="QWidget" name="qfpChartTab">
           <attribute name="title"><string>测量结果</string></attribute>
           <layout class="QGridLayout" name="qfpChartGridLayout">
            <item row="0" column="0">
             <widget class="QLabel" name="qfpCoplanarLabel">
              <property name="text"><string>共面度分布</string></property>
              <property name="alignment"><set>Qt::AlignCenter</set></property>
             </widget>
            </item>
            <item row="0" column="1">
             <widget class="QLabel" name="qfpMaxWarpAngleLabel">
              <property name="text"><string>最大翘曲角</string></property>
              <property name="alignment"><set>Qt::AlignCenter</set></property>
             </widget>
            </item>
            <item row="1" column="0">
